{
  "app-id": "com.radioxide.GUI",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "22.08",
  "sdk": "org.freedesktop.Sdk",
  "command": "radioxide-gui",
  "finish-args": ["--share=network","--socket=x11","--socket=wayland","--device=dri"],
  "modules": [{
    "name": "radioxide",
    "buildsystem": "simple",
    "build-commands": [
      "install -Dm755 target/release/radioxide-gui /app/bin/radioxide-gui",
      "install -Dm755 target/release/radioxide-daemon /app/bin/radioxide-daemon",
      "install -Dm755 target/release/radioxide-cli /app/bin/radioxide-cli"
    ],
    "sources": []
  }]
}
